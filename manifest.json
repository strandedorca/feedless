{
    "manifest_version": 3,
    "name": "Feedless",
    "description": "Hides feed on Instagram and Pinterest.",
    "version": "1.0",
    "content_scripts": [
	    {
			"js": ["content-script.js"],
            "css": ["content-style.css"],
			"matches": ["https://*.pinterest.com/*", "https://*.instagram.com/*"]
	    }
    ]	
}