{
  "manifest_version": 3,
  "name": "Feedless",
  "description": "Hides feeds and recommended content on Pinterest and Instagram so you can focus on creating.",
  "version": "1.0",
  "icons": {
    "48": "icon48.png",
    "96": "icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "pinfocus@noahdev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
 "content_scripts": [
  {
    "js": ["content-script.js"],
    "css": ["content-style.css"],
    "run_at": "document_start",
    "matches": [
      "https://*.pinterest.com/*",
      "https://*.instagram.com/*"
    ]
  }
]
}
